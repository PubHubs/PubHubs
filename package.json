{
	"name": "pubhubs-canonical",
	"version": "3.2.2",
	"private": true,
	"type": "module",
	"description": "PubHubs monorepo",
	"workspaces": [
		"global-client",
		"hub-client"
	],
	"scripts": {
		"prepare": "husky",
		"dev:global": "npm run dev --workspace=global-client",
		"dev:hub": "npm run dev --workspace=hub-client",
		"build:global": "npm run build --workspace=global-client",
		"build:hub": "npm run build --workspace=hub-client",
		"lint": "prettier --write --ignore-unknown \"global-client/src/**/*.{ts,vue,js}\" \"hub-client/src/**/*.{ts,vue,js}\" && eslint --fix global-client/src hub-client/src",
		"check": "npm run check:format && npm run check:lint && npm run check:types",
		"check:format": "prettier --check --ignore-unknown \"global-client/src/**/*.{ts,vue,js}\" \"hub-client/src/**/*.{ts,vue,js}\"",
		"check:lint": "eslint --max-warnings 0 global-client/src hub-client/src",
		"check:types": "npm run type-check --workspace=hub-client && npm run type-check --workspace=global-client"
	},
	"lint-staged": {
		"global-client/src/**/*.{ts,vue,js}": ["prettier --write --ignore-unknown", "eslint --fix"],
		"hub-client/src/**/*.{ts,vue,js}": ["prettier --write --ignore-unknown", "eslint --fix"]
	},
	"devDependencies": {
		"@eslint-community/eslint-plugin-eslint-comments": "^4",
		"@eslint/js": "^9",
		"@trivago/prettier-plugin-sort-imports": "^6.0.0",
		"eslint": "^9",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-vue": "^9",
		"husky": "^9.1.7",
		"jsdom": "^27",
		"lint-staged": "^16",
		"prettier": "^3.5.0",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8"
	}
}
