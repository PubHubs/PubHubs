{
	"name": "@pubhubs/global-client",
	"version": "3.2.2",
	"type": "module",
	"private": true,
	"scripts": {
		"build": "vite build",
		"dev": "vite",
		"pwa": "vite build && npx http-server dist",
		"type-check": "vue-tsc --noEmit",
		"//test": "NODE_OPTIONS=--no-experimental-webstorage disables Node 25's default Web Storage API, which installs a stub globalThis.localStorage that shadows jsdom's. The alternative --localstorage-file=PATH would make Node's storage real, but it backs everything with a single SQLite file that persists across test runs and is shared by parallel workers, breaking test isolation, so it is not a substitute for jsdom's per-window storage. CI on Node 24 only knows the long flag form (the short --no-webstorage alias was added in Node 25). See vitest-dev/vitest#8757 and nodejs/node#57658.",
		"test": "NODE_OPTIONS=--no-experimental-webstorage vitest",
		"test:run": "NODE_OPTIONS=--no-experimental-webstorage vitest run",
		"test:ui": "NODE_OPTIONS=--no-experimental-webstorage vitest --ui",
		"coverage": "NODE_OPTIONS=--no-experimental-webstorage vitest run --coverage"
	},
	"engines": {
		"npm": ">=9.8.1",
		"node": ">=22.0.0"
	},
	"dependencies": {
		"@privacybydesign/yivi-client": "^0",
		"@privacybydesign/yivi-core": "^0",
		"@privacybydesign/yivi-web": "^0",
		"mavon-editor": "^3.0.2",
		"pinia": "^3",
		"typescript-cookie": "^1.0.4",
		"util": "^0.12.5",
		"vue": "^3.2.13",
		"vue-i18n": "^11",
		"vue-router": "^5.0.4",
		"vuedraggable": "^4"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.2.2",
		"@vitejs/plugin-vue": "^6",
		"@vue/test-utils": "^2.2.3",
		"autoprefixer": "^10.4.21",
		"chai": "^6.2.1",
		"jsdoc": "^4.0.2",
		"jsdom": "^29",
		"msw": "^2.12.4",
		"postcss": "^8.5.3",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite-plugin-node-polyfills": "^0.26.0",
		"vite-plugin-pwa": "^1.2.0",
		"vitest": "^4",
		"vue-tsc": "^2"
	},
	"browserslist": [
		"> 1%",
		"last 2 versions",
		"not dead",
		"not ie 11"
	],
	"_id": "@",
	"readme": "ERROR: No README data found!"
